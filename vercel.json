{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "crons": [
    {
      "path": "/api/cron/sync-kpi",
      "schedule": "0 12,13 * * *"
    },
    {
      "path": "/api/cron/reconcile-offers",
      "schedule": "5 0,6,12,18 * * *"
    },
    {
      "path": "/api/cron/sync-kundeavis",
      "schedule": "30 5 * * *"
    }
  ]
}
